<aside class="sidebar">
  <div class="brand">CCA Registrar Office</div>
  <p class="sidebar-role">
    <% if (user.role === "student") { %>Student portal
    <% } else if (user.role === "admin" || user.role === "registrar") { %>Registrar office
    <% } else if (user.role === "department") { %>Department officer
    <% } %>
  </p>

  <nav class="menu">
    <% if (user.role === "student") { %>
      <a href="/student/dashboard" class="<%= active === 'dashboard' ? 'active' : '' %>">My dashboard</a>
      <a href="/student/new-request" class="<%= active === 'new-request' ? 'active' : '' %>">New document request</a>
      <a href="/student/clearance" class="<%= active === 'clearance' ? 'active' : '' %>">My clearance status</a>
      <a href="/change-password" class="<%= active === 'password' ? 'active' : '' %>">Change password</a>
    <% } else if (user.role === "admin" || user.role === "registrar") { %>
      <a href="/admin/dashboard" class="<%= active === 'dashboard' ? 'active' : '' %>">Overview dashboard</a>
      <a href="/admin/requests" class="<%= active === 'requests' ? 'active' : '' %>">Document requests</a>
      <a href="/admin/clearances" class="<%= active === 'clearances' ? 'active' : '' %>">Student clearances</a>
      <a href="/admin/reports" class="<%= active === 'reports' ? 'active' : '' %>">Reports &amp; export</a>
      <a href="/admin/users" class="<%= active === 'users' ? 'active' : '' %>">User accounts</a>
      <a href="/change-password" class="<%= active === 'password' ? 'active' : '' %>">Change password</a>
    <% } else if (user.role === "department") { %>
      <a href="/department/dashboard" class="<%= active === 'dashboard' ? 'active' : '' %>">My office — clearances</a>
      <a href="/change-password" class="<%= active === 'password' ? 'active' : '' %>">Change password</a>
    <% } %>
  </nav>

  <div class="sidebar-foot">
    <p><strong><%= user.displayName %></strong></p>
    <% if (user.role === "admin" || user.role === "registrar") { %>
      <p class="muted tiny">Registrar · <%= user.email || '' %></p>
    <% } else { %>
      <p class="muted tiny"><%= user.email || '' %></p>
    <% } %>
    <% if (user.role === "student") { %>
      <p class="muted tiny">Student ID: <%= user.studentId %></p>
    <% } else if (user.role === "department") { %>
      <p class="muted tiny">Office code: <%= user.departmentCode %></p>
    <% } %>
  </div>
</aside>
