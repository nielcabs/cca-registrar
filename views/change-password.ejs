<!DOCTYPE html>
<html lang="en">
  <head>
    <%- include('partials/head') %>
    <title>Change Password</title>
  </head>
  <body class="app-body">
    <div class="dashboard-shell">
      <%- include('partials/sidebar', { user, active: 'password' }) %>
      <main class="main-panel">
        <%- include('partials/topbar', { title: 'Change Password', subtitle: 'Update your account password.' }) %>

        <section class="card narrow">
          <% if (error) { %><div class="alert error"><%= error %></div><% } %>
          <% if (success) { %><div class="alert success"><%= success %></div><% } %>

          <form method="post" action="/change-password" class="form">
            <label>
              Current Password
              <input type="password" name="currentPassword" required />
            </label>
            <label>
              New Password (min 6 characters)
              <input type="password" name="newPassword" minlength="6" required />
            </label>
            <label>
              Confirm New Password
              <input type="password" name="confirmPassword" minlength="6" required />
            </label>
            <button type="submit">Update Password</button>
          </form>
        </section>
      </main>
    </div>
  </body>
</html>
