<!DOCTYPE html>
<html lang="en">
  <head>
    <%- include('partials/head') %>
    <title>Clearance — <%= studentId %></title>
  </head>
  <body class="app-body">
    <div class="dashboard-shell">
      <%- include('partials/sidebar', { user, active: 'clearances' }) %>
      <main class="main-panel">
        <%- include('partials/topbar', {
          title: 'Student clearance record',
          subtitle: 'Student ID: ' + studentId,
          actionsHtml: '<a class="btn-link" href="/admin/requests">Back to document requests</a> <a class="btn-link" href="/admin/clearances">All students</a>'
        }) %>

        <section class="hero-banner">
          <h2>Overall clearance: <%= summary %></h2>
          <p>
            Prior documents marked <strong>Released</strong> for this student: <strong><%= releasedCount %></strong>.
            Offices update their own rows; this page is read-only for the registrar.
          </p>
        </section>

        <section class="card data-card">
          <div class="card-head"><h2>Per-department status</h2></div>
          <div class="table-wrap">
            <table class="data-table">
              <thead>
                <tr>
                  <th>Department / office</th>
                  <th>Status</th>
                  <th>Remarks</th>
                  <th>Updated by (email)</th>
                  <th>Updated at</th>
                </tr>
              </thead>
              <tbody>
                <% clearances.forEach((c) => { %>
                <tr>
                  <td><%= c.departmentName %></td>
                  <td><span class="badge <%= c.badge %>"><%= c.status %></span></td>
                  <td><%= c.remarks || '—' %></td>
                  <td class="tiny"><%= c.updatedBy || '—' %></td>
                  <td class="tiny"><%= c.updatedAt ? new Date(c.updatedAt).toLocaleString() : '—' %></td>
                </tr>
                <% }) %>
              </tbody>
            </table>
          </div>
        </section>
      </main>
    </div>
  </body>
</html>
