<!DOCTYPE html>
<html lang="en">
  <head>
    <%- include('partials/head') %>
    <title>Overview — CCA Registrar Office</title>
  </head>
  <body class="app-body">
    <div class="dashboard-shell">
      <%- include('partials/sidebar', { user, active: 'dashboard' }) %>
      <main class="main-panel">
        <%- include('partials/topbar', {
          title: 'Registrar office overview',
          subtitle: 'Registrar workspace — document requests, clearances, reports, and user accounts.'
        }) %>

        <section class="hero-banner">
          <h2>Quick actions</h2>
          <p style="margin-bottom: 0.75rem;">Use the sidebar for full menus. Shortcuts:</p>
          <div class="actions" style="flex-wrap: wrap;">
            <a class="btn-solid" href="/admin/requests">Open document request queue</a>
            <a class="btn-solid" href="/admin/clearances">Search student clearances</a>
            <a class="btn-link" href="/admin/reports">View reports</a>
            <a class="btn-link" href="/admin/users">Manage user accounts</a>
          </div>
        </section>

        <section class="stat-grid">
          <article class="stat-card"><h3><%= stats.totalRequests %></h3><p>Total document requests</p></article>
          <article class="stat-card"><h3><%= stats.totalStudents %></h3><p>Registered students</p></article>
          <article class="stat-card"><h3><%= stats.released %></h3><p>Released (completed)</p></article>
          <article class="stat-card"><h3><%= stats.totalUsers %></h3><p>All system accounts</p></article>
        </section>

        <section class="grid">
          <section class="card">
            <div class="card-head"><h2>Request status breakdown</h2></div>
            <dl class="detail-list">
              <div><dt>Submitted</dt><dd><%= stats.submitted %></dd></div>
              <div><dt>For verification</dt><dd><%= stats.forVerification %></dd></div>
              <div><dt>Scheduled</dt><dd><%= stats.scheduled %></dd></div>
              <div><dt>Released</dt><dd><%= stats.released %></dd></div>
              <div><dt>Rejected</dt><dd><%= stats.rejected %></dd></div>
            </dl>
          </section>

          <section class="card">
            <div class="card-head"><h2>Top document types</h2></div>
            <% if (!stats.byDocType.length) { %>
              <p class="muted">No data yet.</p>
            <% } else { %>
              <table class="data-table">
                <thead><tr><th>Document type</th><th>Count</th></tr></thead>
                <tbody>
                  <% stats.byDocType.forEach((d) => { %>
                  <tr><td><%= d.documentType %></td><td><%= d.count %></td></tr>
                  <% }) %>
                </tbody>
              </table>
            <% } %>
          </section>

          <section class="card full">
            <div class="card-head">
              <h2>Latest document requests</h2>
              <a class="btn-link" href="/admin/requests">View full queue</a>
            </div>
            <% if (!recent.length) { %>
              <p class="muted">No requests yet.</p>
            <% } else { %>
              <div class="table-wrap">
                <table class="data-table">
                  <thead>
                    <tr>
                      <th>Request ID</th><th>Student</th><th>Document</th><th>Status</th><th>Created</th><th></th>
                    </tr>
                  </thead>
                  <tbody>
                    <% recent.forEach((r) => { %>
                    <tr>
                      <td><%= r.id %></td>
                      <td><%= r.studentName %> (<%= r.studentId %>)</td>
                      <td><%= r.documentType %></td>
                      <td><span class="badge <%= r.statusClass %>"><%= r.status %></span></td>
                      <td class="tiny"><%= new Date(r.createdAt).toLocaleString() %></td>
                      <td><a class="table-link" href="/admin/request/<%= r.id %>">Process</a></td>
                    </tr>
                    <% }) %>
                  </tbody>
                </table>
              </div>
            <% } %>
          </section>
        </section>
      </main>
    </div>
  </body>
</html>
