<!DOCTYPE html>
<html lang="en">
  <head>
    <%- include('partials/head') %>
    <title>Overview — CCA Registrar Office</title>
  </head>
  <body class="app-body">
    <div class="dashboard-shell">
      <%- include('partials/sidebar', { user, active: active || 'dashboard' }) %>
      <main class="main-panel">
        <%- include('partials/topbar', {
          title: 'Registrar dashboard',
          subtitle: 'Document requisitions, OCR validation, release scheduling, and student lookup.'
        }) %>

        <section class="card" style="margin-bottom: 1rem;">
          <form method="get" action="/admin/dashboard" class="form two-col" style="align-items: end;">
            <label class="full-row">
              Search students &amp; requests (filters the table below; same data as the full queue)
              <input type="search" name="q" value="<%= typeof searchQuery !== 'undefined' ? searchQuery : '' %>" placeholder="Student name, ID, document type, or request ID (e.g. Juan, 20230001, DEMO1001)" />
            </label>
            <button type="submit">Search</button>
            <% if (typeof searchQuery !== 'undefined' && searchQuery) { %>
            <a class="btn-link" href="/admin/dashboard">Clear search</a>
            <a class="btn-link" href="/admin/requests?q=<%= encodeURIComponent(searchQuery) %>">Open full queue</a>
            <% } %>
          </form>
        </section>

        <section class="hero-banner">
          <h2>Quick actions</h2>
          <p style="margin-bottom: 0.75rem;">Use the sidebar for full menus. Shortcuts:</p>
          <div class="actions" style="flex-wrap: wrap;">
            <a class="btn-solid" href="/admin/requests">Open document request queue</a>
            <a class="btn-solid" href="/admin/clearances">Search student clearances</a>
            <a class="btn-link" href="/admin/reports">View reports</a>
            <a class="btn-link" href="/admin/users">Manage user accounts</a>
          </div>
        </section>

        <section class="stat-grid">
          <article class="stat-card"><h3><%= recent.length %></h3><p>Requests shown below<% if (typeof searchQuery !== 'undefined' && searchQuery) { %> (search)<% } %></p></article>
          <article class="stat-card"><h3><%= stats.forVerification %></h3><p>For verification (office-wide)</p></article>
          <article class="stat-card"><h3><%= stats.scheduled %></h3><p>Scheduled (office-wide)</p></article>
          <article class="stat-card"><h3><%= typeof ocrProcessedCount !== 'undefined' ? ocrProcessedCount : 0 %></h3><p>OCR processed<% if (typeof searchQuery !== 'undefined' && searchQuery) { %> (matches search)<% } else { %> (all requests)<% } %></p></article>
        </section>

        <section class="grid">
          <section class="card">
            <div class="card-head"><h2>Request status breakdown</h2></div>
            <dl class="detail-list">
              <div><dt>Submitted</dt><dd><%= stats.submitted %></dd></div>
              <div><dt>For verification</dt><dd><%= stats.forVerification %></dd></div>
              <div><dt>Scheduled</dt><dd><%= stats.scheduled %></dd></div>
              <div><dt>Released</dt><dd><%= stats.released %></dd></div>
              <div><dt>Rejected</dt><dd><%= stats.rejected %></dd></div>
            </dl>
          </section>

          <section class="card">
            <div class="card-head"><h2>Top document types</h2></div>
            <% if (!stats.byDocType.length) { %>
              <p class="muted">No data yet.</p>
            <% } else { %>
              <table class="data-table">
                <thead><tr><th>Document type</th><th>Count</th></tr></thead>
                <tbody>
                  <% stats.byDocType.forEach((d) => { %>
                  <tr><td><%= d.documentType %></td><td><%= d.count %></td></tr>
                  <% }) %>
                </tbody>
              </table>
            <% } %>
          </section>

          <section class="card full">
            <div class="card-head">
              <h2><%= (typeof searchQuery !== 'undefined' && searchQuery) ? 'Matching requests' : 'Latest document requests' %></h2>
              <a class="btn-link" href="/admin/requests<%= typeof searchQuery !== 'undefined' && searchQuery ? ('?q=' + encodeURIComponent(searchQuery)) : '' %>">View full queue</a>
            </div>
            <% if (!recent.length) { %>
              <p class="muted"><%= (typeof searchQuery !== 'undefined' && searchQuery) ? 'No requests match this search. Try another name, ID, or request number.' : 'No requests yet.' %></p>
            <% } else { %>
              <div class="table-wrap">
                <table class="data-table">
                  <thead>
                    <tr>
                      <th>Request ID</th><th>Student</th><th>Document</th><th>Status</th><th>Created</th><th></th>
                    </tr>
                  </thead>
                  <tbody>
                    <% recent.forEach((r) => { %>
                    <tr>
                      <td><%= r.id %></td>
                      <td><%= r.studentName %> (<%= r.studentId %>)</td>
                      <td><%= r.documentType %></td>
                      <td><span class="badge <%= r.statusClass %>"><%= r.status %></span></td>
                      <td class="tiny"><%= new Date(r.createdAt).toLocaleString() %></td>
                      <td><a class="table-link" href="/admin/request/<%= r.id %>">Process</a></td>
                    </tr>
                    <% }) %>
                  </tbody>
                </table>
              </div>
            <% } %>
          </section>
        </section>
      </main>
    </div>
  </body>
</html>
