<!DOCTYPE html>
<html lang="en">
  <head>
    <%- include('partials/head') %>
    <title>Verify Students</title>
  </head>
  <body class="app-body">
    <div class="dashboard-shell">
      <%- include('partials/sidebar', { user, active: 'verify' }) %>
      <main class="main-panel">
        <%- include('partials/topbar', {
          title: 'Student Verification',
          subtitle: 'Validate registered students before they can submit requests.'
        }) %>

        <section class="hero-banner">
          <h2>Student Verification Module</h2>
          <p>Confirm that registered student accounts match enrolled CCA students.</p>
        </section>

        <section class="card data-card">
          <div class="card-head"><h2>Registered Students (<%= students.length %>)</h2></div>
          <div class="table-wrap">
            <table class="data-table">
              <thead>
                <tr>
                  <th>Student ID</th><th>Name</th><th>Email</th><th>Status</th><th>Registered</th><th>Action</th>
                </tr>
              </thead>
              <tbody>
                <% if (!students.length) { %>
                <tr><td colspan="6" class="muted center">No student accounts yet.</td></tr>
                <% } %>
                <% students.forEach((s) => { %>
                <tr>
                  <td><%= s.studentId %></td>
                  <td><%= s.displayName %></td>
                  <td><%= s.email %></td>
                  <td>
                    <% if (s.isVerified) { %>
                      <span class="badge badge-released">Verified</span>
                    <% } else { %>
                      <span class="badge badge-verify">Pending</span>
                    <% } %>
                  </td>
                  <td class="tiny"><%= new Date(s.createdAt).toLocaleString() %></td>
                  <td>
                    <% if (!s.isVerified) { %>
                    <form method="post" action="/admin/users/<%= s.id %>/verify" style="display:inline;">
                      <button type="submit" class="btn-solid tiny">Verify Now</button>
                    </form>
                    <% } else { %>
                    <form method="post" action="/admin/users/<%= s.id %>/unverify" style="display:inline;">
                      <button type="submit" class="ghost tiny">Revoke</button>
                    </form>
                    <% } %>
                  </td>
                </tr>
                <% }) %>
              </tbody>
            </table>
          </div>
        </section>
      </main>
    </div>
  </body>
</html>
