<!DOCTYPE html>
<html lang="en">
  <head>
    <%- include('partials/head') %>
    <title>Clearance - <%= studentId %></title>
  </head>
  <body class="app-body">
    <div class="dashboard-shell">
      <%- include('partials/sidebar', { user, active: 'dashboard' }) %>
      <main class="main-panel">
        <%- include('partials/topbar', {
          title: 'Student Clearance Overview',
          subtitle: 'Student ID: ' + studentId,
          actionsHtml: '<a class="btn-link" href="/registrar/dashboard">Back to Dashboard</a>'
        }) %>

        <section class="hero-banner">
          <h2>Overall: <%= summary %></h2>
          <p>Read-only view for registrar. Department officers manage their own clearances.</p>
        </section>

        <section class="card data-card">
          <div class="card-head">
            <h2>Departments</h2>
          </div>
          <div class="table-wrap">
            <table class="data-table">
              <thead>
                <tr>
                  <th>Department</th>
                  <th>Status</th>
                  <th>Remarks</th>
                  <th>Updated By</th>
                  <th>Updated At</th>
                </tr>
              </thead>
              <tbody>
                <% clearances.forEach((c) => { %>
                <tr>
                  <td><%= c.departmentName %></td>
                  <td><span class="badge <%= c.badge %>"><%= c.status %></span></td>
                  <td><%= c.remarks || '—' %></td>
                  <td class="tiny"><%= c.updatedBy || '—' %></td>
                  <td class="tiny"><%= c.updatedAt ? new Date(c.updatedAt).toLocaleString() : '—' %></td>
                </tr>
                <% }) %>
              </tbody>
            </table>
          </div>
        </section>
      </main>
    </div>
  </body>
</html>
