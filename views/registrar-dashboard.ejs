<!DOCTYPE html>
<html lang="en">
  <head>
    <%- include('partials/head') %>
    <title>Registrar Dashboard</title>
  </head>
  <body class="app-body">
    <% const forVerificationCount = requests.filter((item) => item.status === "For Verification").length; %>
    <% const scheduledCount = requests.filter((item) => item.status === "Scheduled").length; %>
    <% const releasedCount = requests.filter((item) => item.status === "Released").length; %>
    <% const ocrProcessedCount = requests.filter((item) => item.ocr?.state === "processed" || item.ocr?.state === "corrected").length; %>

    <div class="dashboard-shell">
      <%- include('partials/sidebar', { user, active: 'dashboard' }) %>
      <main class="main-panel">
        <%- include('partials/topbar', {
          title: 'Registrar Dashboard',
          subtitle: 'Manage requisitions, OCR validation, and release scheduling.'
        }) %>

        <section class="hero-banner">
          <h2>Service Operations Overview</h2>
          <p>Centralized monitoring of request progress, clearance status, and OCR-assisted verification.</p>
        </section>

        <section class="stat-grid">
          <article class="stat-card">
            <h3><%= requests.length %></h3>
            <p>Total Requests</p>
          </article>
          <article class="stat-card">
            <h3><%= forVerificationCount %></h3>
            <p>For Verification</p>
          </article>
          <article class="stat-card">
            <h3><%= scheduledCount %></h3>
            <p>Scheduled</p>
          </article>
          <article class="stat-card">
            <h3><%= ocrProcessedCount %></h3>
            <p>OCR Processed</p>
          </article>
        </section>

        <section class="card data-card">
          <div class="card-head">
            <h2>Request Queue</h2>
            <p class="muted">Released: <%= releasedCount %></p>
          </div>
          <div class="table-wrap">
            <table class="data-table">
              <thead>
                <tr>
                  <th>Request ID</th>
                  <th>Student</th>
                  <th>Doc Type</th>
                  <th>Status</th>
                  <th>Clearance</th>
                  <th>OCR</th>
                  <th>Schedule</th>
                  <th>Created</th>
                  <th>Action</th>
                </tr>
              </thead>
              <tbody>
                <% if (!requests.length) { %>
                <tr><td colspan="9" class="muted center">No requests submitted yet.</td></tr>
                <% } %>
                <% requests.forEach((item) => { %>
                <tr>
                  <td><%= item.id %></td>
                  <td>
                    <%= item.studentName %> (<%= item.studentId %>)
                    <div class="tiny"><a class="table-link" href="/registrar/clearance/<%= item.studentId %>">View clearance</a></div>
                  </td>
                  <td><%= item.documentType %></td>
                  <td><span class="badge <%= item.statusClass %>"><%= item.status %></span></td>
                  <td><%= item.clearanceStatus %></td>
                  <td><%= item.ocr?.state || "not_run" %></td>
                  <td><%= item.schedule ? `${item.schedule.date} ${item.schedule.time}` : '—' %></td>
                  <td class="tiny"><%= new Date(item.createdAt).toLocaleString() %></td>
                  <td><a class="table-link" href="/registrar/request/<%= item.id %>">Open</a></td>
                </tr>
                <% }) %>
              </tbody>
            </table>
          </div>
        </section>
      </main>
    </div>
  </body>
</html>
