<!DOCTYPE html>
<html lang="en">
  <head>
    <%- include('partials/head') %>
    <title>CCA Registrar System - Login</title>
    <style>
      /* Inline fallback if an old styles.css is cached without green auth rules */
      body.auth-bg {
        background: linear-gradient(135deg, #14532d 0%, #15803d 38%, #22c55e 100%) !important;
      }
      body.auth-bg .auth-card button[type="submit"] {
        background: #166534 !important;
        border: 1px solid #14532d !important;
      }
      body.auth-bg .auth-card button[type="submit"]:hover {
        background: #14532d !important;
      }
    </style>
  </head>
  <body class="auth-bg">
    <main class="card auth-card">
      <h1>CCA Registrar Office Portal</h1>
      <p class="muted">Integrated requisition, clearance tracking, and release scheduling</p>

      <% if (error) { %>
      <div class="alert error"><%= error %></div>
      <% } %>
      <% if (success) { %>
      <div class="alert success"><%= success %></div>
      <% } %>

      <form method="post" action="/login" class="form">
        <label>
          Email
          <input type="email" name="email" placeholder="you@cca.edu.ph" required autofocus />
        </label>
        <label>
          Password
          <input type="password" name="password" required />
        </label>
        <button type="submit">Login</button>
      </form>

      <p class="tiny muted" style="margin-top: 0.8rem;">
        New student? <a href="/register">Create an account</a>
      </p>
    </main>
  </body>
</html>
