<!DOCTYPE html>
<html lang="en">
  <head>
    <%- include('partials/head') %>
    <title><%= department.name %> - Clearance Management</title>
  </head>
  <body class="app-body">
    <div class="dashboard-shell">
      <%- include('partials/sidebar', { user, active: 'dashboard' }) %>
      <main class="main-panel">
        <%- include('partials/topbar', {
          title: department.name,
          subtitle: 'Update your department\'s clearance status for each student.'
        }) %>

        <% if (message) { %><div class="alert success"><%= message %></div><% } %>

        <section class="hero-banner">
          <h2>Department Clearance Module</h2>
          <p>Your updates are visible to the student and registrar in real-time.</p>
        </section>

        <section class="card data-card">
          <div class="card-head"><h2>Students (<%= students.length %>)</h2></div>
          <div class="table-wrap">
            <table class="data-table">
              <thead>
                <tr>
                  <th>Student ID</th>
                  <th>Name / Email</th>
                  <th>Current Status</th>
                  <th>Last Updated</th>
                  <th>Update</th>
                </tr>
              </thead>
              <tbody>
                <% if (!students.length) { %>
                <tr><td colspan="5" class="muted center">No students registered yet.</td></tr>
                <% } %>
                <% students.forEach((s) => { %>
                <tr>
                  <td><%= s.studentId %></td>
                  <td>
                    <strong><%= s.displayName %></strong>
                    <div class="tiny muted"><%= s.email %></div>
                    <% if (!s.isVerified) { %><span class="tiny badge badge-verify">Unverified</span><% } %>
                  </td>
                  <td>
                    <span class="badge <%= s.badge %>"><%= s.status %></span>
                    <% if (s.remarks) { %><div class="tiny muted"><%= s.remarks %></div><% } %>
                  </td>
                  <td class="tiny"><%= s.updatedAt ? new Date(s.updatedAt).toLocaleString() : '—' %></td>
                  <td>
                    <form method="post" action="/department/update/<%= s.studentId %>" class="form" style="gap:0.3rem;">
                      <select name="status" required>
                        <% ["Pending","Cleared","Not Cleared"].forEach((v) => { %>
                        <option value="<%= v %>" <%= s.status === v ? 'selected' : '' %>><%= v %></option>
                        <% }) %>
                      </select>
                      <input type="text" name="remarks" value="<%= s.remarks || '' %>" placeholder="Remarks (optional)" />
                      <button type="submit" class="tiny">Save</button>
                    </form>
                  </td>
                </tr>
                <% }) %>
              </tbody>
            </table>
          </div>
        </section>
      </main>
    </div>
  </body>
</html>
