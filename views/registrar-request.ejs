<!DOCTYPE html>
<html lang="en">
  <head>
    <%- include('partials/head') %>
    <title>Registrar Request <%= request.id %></title>
  </head>
  <body class="app-body">
    <div class="dashboard-shell">
      <%- include('partials/sidebar', { user, active: 'dashboard' }) %>
      <main class="main-panel">
        <%- include('partials/topbar', {
          title: 'Request ' + request.id,
          subtitle: 'Student: ' + request.studentName + ' (' + request.studentId + ')',
          actionsHtml: '<a class="btn-link" href="/registrar/dashboard">Back to Dashboard</a>'
        }) %>

        <section class="hero-banner">
          <h2>Processing Status: <%= request.status %></h2>
          <p>
            Live Clearance: <span class="badge <%= clearanceSummaryBadge %>"><%= clearanceSummary %></span>
            | OCR state: <%= request.ocr?.state || "not_run" %>
          </p>
        </section>

        <% if (message) { %>
        <section class="card full"><div class="alert success"><%= message %></div></section>
        <% } %>
        <% if (error) { %>
        <section class="card full"><div class="alert error"><%= error %></div></section>
        <% } %>

        <section class="grid">
          <section class="card">
            <h2>Submitted Proof</h2>
            <p><a class="table-link" href="<%= request.uploadedFilePath %>" target="_blank">Open file</a></p>
            <img src="<%= request.uploadedFilePath %>" alt="Uploaded proof" class="preview" />
            <form method="post" action="/registrar/request/<%= request.id %>/run-ocr">
              <button type="submit">Run OCR</button>
            </form>
            <p class="tiny muted">OCR is assistive. Final validation is still manual.</p>
          </section>

          <section class="card">
            <h2>Request Information</h2>
            <dl class="detail-list">
              <div><dt>Document Type</dt><dd><%= request.documentType %></dd></div>
              <div><dt>Purpose</dt><dd><%= request.purpose %></dd></div>
              <div><dt>Submitted</dt><dd><%= dayjs(request.createdAt).format("MMM D, YYYY h:mm A") %></dd></div>
              <div><dt>Current Status</dt><dd><%= request.status %></dd></div>
            </dl>
          </section>

          <section class="card full">
            <h2>Student Clearance Across Departments</h2>
            <div class="table-wrap">
              <table class="data-table">
                <thead>
                  <tr>
                    <th>Department</th>
                    <th>Status</th>
                    <th>Remarks</th>
                    <th>Last Updated</th>
                  </tr>
                </thead>
                <tbody>
                  <% clearances.forEach((c) => { %>
                  <tr>
                    <td><%= c.departmentName %></td>
                    <td><span class="badge <%= c.badge %>"><%= c.status %></span></td>
                    <td><%= c.remarks || '—' %></td>
                    <td class="tiny muted"><%= c.updatedAt ? new Date(c.updatedAt).toLocaleString() : '—' %></td>
                  </tr>
                  <% }) %>
                </tbody>
              </table>
            </div>
            <p class="tiny muted">A request can only be marked "Scheduled" or "Released" when all 6 departments are Cleared.</p>
          </section>

          <section class="card full">
            <h2>Review and Update</h2>
            <form method="post" action="/registrar/request/<%= request.id %>/update" class="form two-col">
              <label>
                Status
                <select name="status" required>
                  <% ["Submitted","For Verification","Scheduled","Released","Rejected"].forEach((value) => { %>
                  <option value="<%= value %>" <%= request.status === value ? "selected" : "" %>><%= value %></option>
                  <% }) %>
                </select>
              </label>

              <label>
                Pick Release Slot
                <select name="scheduleSlot" id="scheduleSlot">
                  <option value="">-- Select slot --</option>
                  <% slots.forEach((slot) => { %>
                  <option value="<%= slot.date %>|<%= slot.time %>"
                    <%= (request.schedule?.date === slot.date && request.schedule?.time === slot.time) ? 'selected' : '' %>
                    <%= !slot.available && !(request.schedule?.date === slot.date && request.schedule?.time === slot.time) ? 'disabled' : '' %>>
                    <%= slot.date %> <%= slot.time %>
                    (<%= slot.booked %>/<%= slot.capacity %><%= slot.available ? '' : ' FULL' %>)
                  </option>
                  <% }) %>
                </select>
              </label>

              <input type="hidden" name="scheduleDate" id="scheduleDate" value="<%= request.schedule?.date || '' %>" />
              <input type="hidden" name="scheduleTime" id="scheduleTime" value="<%= request.schedule?.time || '' %>" />

              <label>
                OCR Student Name
                <input type="text" name="extractedStudentName" value="<%= request.ocr?.extracted?.studentName || '' %>" />
              </label>
              <label>
                OCR Student ID
                <input type="text" name="extractedStudentId" value="<%= request.ocr?.extracted?.studentId || '' %>" />
              </label>
              <label>
                OCR OR Number
                <input type="text" name="extractedOrNumber" value="<%= request.ocr?.extracted?.orNumber || '' %>" />
              </label>
              <label>
                OCR Amount
                <input type="text" name="extractedAmount" value="<%= request.ocr?.extracted?.amount || '' %>" />
              </label>
              <label>
                OCR Payment Date
                <input type="text" name="extractedPaymentDate" value="<%= request.ocr?.extracted?.paymentDate || '' %>" />
              </label>

              <label class="full-row">
                Registrar Remarks
                <textarea name="registrarRemarks" rows="3" placeholder="Reason for rejection, release instructions, etc."><%= request.registrarRemarks || '' %></textarea>
              </label>

              <button type="submit">Save Updates</button>
            </form>

            <h3>OCR Raw Text (trimmed)</h3>
            <pre class="raw-ocr"><%= request.ocr?.rawText || "No OCR text yet." %></pre>
            <p class="tiny muted">
              OCR state: <strong><%= request.ocr?.state || "not_run" %></strong>
              <% if (request.ocr?.confidence !== null && request.ocr?.confidence !== undefined) { %>
              | confidence: <strong><%= request.ocr.confidence %>%</strong>
              <% } %>
            </p>
          </section>
        </section>
      </main>
    </div>

    <script>
      (function () {
        var slotSelect = document.getElementById("scheduleSlot");
        var dateInput = document.getElementById("scheduleDate");
        var timeInput = document.getElementById("scheduleTime");
        function sync() {
          var val = slotSelect.value;
          if (!val) {
            dateInput.value = "";
            timeInput.value = "";
            return;
          }
          var parts = val.split("|");
          dateInput.value = parts[0];
          timeInput.value = parts[1];
        }
        slotSelect.addEventListener("change", sync);
        sync();
      })();
    </script>
  </body>
</html>
