<!DOCTYPE html>
<html lang="en">
  <head>
    <%- include('partials/head') %>
    <title>User accounts</title>
  </head>
  <body class="app-body">
    <div class="dashboard-shell">
      <%- include('partials/sidebar', { user, active: 'users' }) %>
      <main class="main-panel">
        <%- include('partials/topbar', {
          title: 'User account management',
          subtitle: 'Create student or department officer logins, or remove accounts. The registrar / admin role is not created here — use the seeded admin account.'
        }) %>

        <% if (error) { %><div class="alert error"><%= error %></div><% } %>
        <% if (success) { %><div class="alert success"><%= success %></div><% } %>

        <section class="card" style="margin-bottom: 1rem;">
          <h2>Create new account</h2>
          <p class="tiny muted" style="margin-top:0;">Students can also self-register from the login page. New students can submit requests immediately after registration.</p>
          <form method="post" action="/admin/users/create" class="form two-col">
            <label>
              Account role
              <select name="role" id="roleSelect" required>
                <option value="">Select role</option>
                <option value="student">Student</option>
                <option value="department">Department officer (Library, Finance, etc.)</option>
                <option value="admin">Additional administrator</option>
              </select>
            </label>
            <label>
              Full display name
              <input type="text" name="displayName" required placeholder="As it should appear in the system" />
            </label>
            <label>
              Email (used as login)
              <input type="email" name="email" required placeholder="name@cca.edu.ph" />
            </label>
            <label>
              Initial password (min. 6 characters)
              <input type="password" name="password" minlength="6" required />
            </label>
            <label id="studentIdField" style="display:none;">
              Student ID number
              <input type="text" name="studentId" placeholder="e.g. 2023001234" />
            </label>
            <label id="deptField" style="display:none;">
              Department (for officer login)
              <select name="departmentCode">
                <option value="">Select department</option>
                <% departments.forEach((d) => { %>
                <option value="<%= d.code %>"><%= d.name %></option>
                <% }) %>
              </select>
            </label>
            <button type="submit" class="full-row">Create account</button>
          </form>
        </section>

        <section class="card data-card">
          <div class="card-head"><h2>All accounts (<%= users.length %>)</h2></div>
          <div class="table-wrap">
            <table class="data-table">
              <thead>
                <tr>
                  <th>Email (login)</th>
                  <th>Display name</th>
                  <th>Role</th>
                  <th>Student ID / office</th>
                  <th>Created</th>
                  <th>Actions</th>
                </tr>
              </thead>
              <tbody>
                <% users.forEach((u) => { %>
                <tr>
                  <td><%= u.email %></td>
                  <td><%= u.displayName %></td>
                  <td><%= u.role %></td>
                  <td><%= u.studentId || u.departmentCode || '—' %></td>
                  <td class="tiny"><%= new Date(u.createdAt).toLocaleDateString() %></td>
                  <td>
                    <% if (u.email !== user.email) { %>
                    <form method="post" action="/admin/users/<%= u.id %>/delete" style="display:inline;" onsubmit="return confirm('Permanently delete <%= u.email %>?');">
                      <button type="submit" class="ghost tiny">Delete</button>
                    </form>
                    <% } else { %>
                    <span class="muted tiny">Current session</span>
                    <% } %>
                  </td>
                </tr>
                <% }) %>
              </tbody>
            </table>
          </div>
        </section>
      </main>
    </div>

    <script>
      (function () {
        var roleSelect = document.getElementById("roleSelect");
        var sidField = document.getElementById("studentIdField");
        var deptField = document.getElementById("deptField");
        var sidInput = sidField.querySelector("input");
        var deptSelect = deptField.querySelector("select");
        function sync() {
          var v = roleSelect.value;
          sidField.style.display = v === "student" ? "block" : "none";
          deptField.style.display = v === "department" ? "block" : "none";
          sidInput.required = v === "student";
          deptSelect.required = v === "department";
        }
        roleSelect.addEventListener("change", sync);
        sync();
      })();
    </script>
  </body>
</html>
